rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Analyses and chat/negotiation side data are written only via Admin SDK (BFF).
    match /analyses/{analysisId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;

      match /chats/{chatId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/analyses/$(analysisId)).data.userId == request.auth.uid;
        allow write: if false;
      }

      match /negotiationState/{docId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/analyses/$(analysisId)).data.userId == request.auth.uid;
        allow write: if false;
      }
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Job queue is Admin-only (Cloud Functions worker).
    match /analysisJobs/{jobId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
