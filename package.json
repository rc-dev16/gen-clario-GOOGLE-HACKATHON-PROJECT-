{
  "name": "legal-document-analyzer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:functions": "firebase emulators:start --only functions",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:functions\"",
    "build": "vite build",
    "build:functions": "npm run build --prefix functions",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "lint": "eslint .",
    "preview": "vite preview",
    "storage:cors": "node scripts/configure-storage-cors.js"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.7.0",
    "@tanstack/react-query": "^5.101.2",
    "@types/uuid": "^10.0.0",
    "date-fns": "^4.1.0",
    "firebase": "^11.10.0",
    "jspdf": "^3.0.1",
    "lucide-react": "^0.344.0",
    "pdfjs-dist": "^5.3.93",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
